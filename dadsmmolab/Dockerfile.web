# MyAAC website + cast login, self-contained (nginx + php-fpm via supervisor).
# NOTE: MyAAC dockerization is the least-tested part of this stack — verify on a
# Docker host. MyAAC normally has a web installer; here config.local.php is
# generated from env and database_auto_migrate handles its schema additions.
FROM php:8.1-fpm

ARG MYAAC_GIT=https://github.com/slawkens/myaac.git
ARG MYAAC_BRANCH=master
ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
      nginx supervisor git unzip libzip-dev libpng-dev libjpeg-dev libfreetype6-dev \
      libonig-dev ca-certificates \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install -j"$(nproc)" pdo_mysql gd zip bcmath \
    && rm -rf /var/lib/apt/lists/*

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

WORKDIR /var/www/html
RUN git clone --branch "$MYAAC_BRANCH" --depth 1 "$MYAAC_GIT" . \
    && composer install --no-dev --no-interaction --optimize-autoloader || true

# Overlay our cast-aware login.php (intercepts @cast).
COPY deployment/web/login.php /var/www/html/login.php

COPY dadsmmolab/nginx.conf /etc/nginx/sites-available/default
COPY dadsmmolab/supervisord.conf /etc/supervisor/conf.d/web.conf
COPY dadsmmolab/web-entrypoint.sh /usr/local/bin/web-entrypoint.sh
RUN chmod +x /usr/local/bin/web-entrypoint.sh \
    && chown -R www-data:www-data /var/www/html

EXPOSE 80
ENTRYPOINT ["/usr/local/bin/web-entrypoint.sh"]

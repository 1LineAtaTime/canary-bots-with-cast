# ==========================================================================
# dadsmmolab one-install environment. Copy to `.env` (install.sh does this)
# and adjust. Defaults assume a single-machine local install (127.0.0.1).
# ==========================================================================

# ---- Build mode ----------------------------------------------------------
# prebuilt = download compiled canary + libbot_engine.so from GitHub Releases
# compile  = build from source inside Docker (vcpkg, ~30-60 min first run)
SERVER_BUILD_TARGET=prebuilt
# Release asset base URL used when SERVER_BUILD_TARGET=prebuilt.
# Must serve `canary` and `libbot_engine.so`. Set to this repo's Releases.
RELEASE_ASSETS_URL=https://github.com/1LineAtaTime/canary-bots-with-cast/releases/latest/download

# ---- Database (MariaDB) --------------------------------------------------
# Local-install defaults — CHANGE these before exposing the server publicly.
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=canary
MYSQL_USER=canary
MYSQL_PASSWORD=canary
MYSQL_HOST=database
MYSQL_PORT=3306

# ---- Server --------------------------------------------------------------
SERVER_NAME=Canary Bots
SERVER_IP=127.0.0.1
LOGIN_PORT=7171
GAME_PORT=7172
STATUS_PORT=7171
# World map (downloaded if missing). Match your base Canary version.
MAP_URL=https://github.com/opentibiabr/canary/releases/download/v3.1.0/otservbr.otbm
# How many bot players to load (0-997). See BOT_SYSTEM_DOCS.md.
BOT_PLAYERS_ONLINE=500

# ---- Web (MyAAC) ---------------------------------------------------------
WEB_HTTP_PORT=80
MYAAC_GIT=https://github.com/slawkens/myaac.git
MYAAC_BRANCH=master

# ---- Client assets (Tibia.dat / Tibia.spr) -------------------------------
# The server is Canary protocol 15.x; OTClient Redemption stores the matching
# Tibia.dat/Tibia.spr under its data/things/1100/ folder. These are copyrighted
# CipSoft assets and are NOT bundled. Provide a URL to a .zip/.tar.gz (or direct
# file URL) containing Tibia.dat and Tibia.spr; they will be served for download.
# Leave blank to skip (place them manually in the client). Where to obtain them:
#   https://downloads.ots.me/?dir=data/tibia-clients/dat_and_spr/
#   https://github.com/dudantas/tibia-client/releases/tag/15.11.c9d1cf
#   https://github.com/opentibiabr/otclient/wiki/Tutorial-Protocol-12.x-assets
CLIENT_ASSETS_URL=
